{
  "name": "dialog",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "vite --port 5175",
    "prebuild": "tsc --build",
    "build": "vite build && tsx scripts/check-css.ts",
    "check": "biome check --write --unsafe",
    "check:css": "tsx scripts/check-css.ts",
    "check:types": "tsc --noEmit",
    "check:types_fast": "tsgo --noEmit",
    "prepreview": "pnpm build",
    "preview": "vite preview",
    "sync:ui-assets": "rm -rf public/ui && cp -r ../ui/assets public/ui",
    "generate:error-selectors": "tsx scripts/generate-error-selectors.ts > src/lib/generated-error-selectors.ts"
  },
  "dependencies": {
    "@ariakit/react": "catalog:",
    "@porto/apps": "workspace:*",
    "@porto/ui": "workspace:*",
    "@sentry/react": "catalog:",
    "@sentry/vite-plugin": "catalog:",
    "@tanstack/query-sync-storage-persister": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-persist-client": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@wagmi/core": "catalog:",
    "cva": "catalog:",
    "lucide-react": "^0.563.0",
    "mipd": "catalog:",
    "mipd-postmessage": "catalog:",
    "ox": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-intersection-observer": "^10.0.2",
    "rise-wallet": "workspace:*",
    "wagmi": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@iconify/json": "catalog:",
    "@pandacss/dev": "catalog:",
    "@porto/apps": "workspace:*",
    "@svgr/core": "catalog:",
    "@svgr/plugin-jsx": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "globals": "catalog:",
    "postcss": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "unplugin-icons": "catalog:",
    "vite": "catalog:",
    "vite-plugin-mkcert": "catalog:",
    "vite-plugin-terminal": "^1.4.0",
    "vite-tsconfig-paths": "^6.1.0"
  },
  "repository": {
    "type": "git",
    "directory": "apps/dialog",
    "url": "https://github.com/ithacaxyz/porto"
  }
}
