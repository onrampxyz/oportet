{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "autoJobCancelation": true
  },
  "rewrites": [
    {
      "destination": "/.well-known/m/apple-staging.txt",
      "has": [
        {
          "type": "host",
          "value": "stg.id.porto.sh"
        }
      ],
      "source": "/.well-known/apple-developer-merchantid-domain-association.txt"
    },
    {
      "destination": "/.well-known/m/apple-staging2.txt",
      "has": [
        {
          "type": "host",
          "value": "id.porto.sh"
        }
      ],
      "source": "/.well-known/apple-developer-merchantid-domain-association.txt"
    },
    {
      "destination": "/.well-known/m/apple-prod.txt",
      "has": [
        {
          "type": "host",
          "value": "prod.id.porto.sh"
        }
      ],
      "source": "/.well-known/apple-developer-merchantid-domain-association.txt"
    },
    {
      "destination": "https://rise-wallet-testnet-dialog-:env.vercel.app/dialog/",
      "has": [
        {
          "type": "host",
          "value": "rise-wallet-testnet-(?<env>[^.]+).vercel.app"
        }
      ],
      "source": "/dialog/"
    },
    {
      "destination": "https://rise-wallet-testnet-dialog-:env.vercel.app/dialog/:match*",
      "has": [
        {
          "type": "host",
          "value": "rise-wallet-testnet-(?<env>[^.]+).vercel.app"
        }
      ],
      "source": "/dialog/:match*"
    },
    {
      "destination": "https://rise-wallet-testnet-id-:env.vercel.app/",
      "has": [
        {
          "type": "host",
          "value": "rise-wallet-testnet-(?<env>[^.]+).vercel.app"
        }
      ],
      "source": "/"
    },
    {
      "destination": "https://rise-wallet-testnet-id-:env.vercel.app/:match*",
      "has": [
        {
          "type": "host",
          "value": "rise-wallet-testnet-(?<env>[^.]+).vercel.app"
        }
      ],
      "source": "/:match*"
    },
    {
      "destination": "https://rise-wallet-dialog.vercel.app/dialog/",
      "source": "/dialog/"
    },
    {
      "destination": "https://rise-wallet-dialog.vercel.app/dialog/:match*",
      "source": "/dialog/:match*"
    },
    { "destination": "https://rise-wallet-id.vercel.app/", "source": "/" },
    {
      "destination": "https://rise-wallet-id.vercel.app/:match*",
      "source": "/:match*"
    }
  ]
}
