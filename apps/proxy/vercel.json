{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "autoJobCancelation": true
  },
  "rewrites": [
    {
      "destination": "https://:env.dialog.wallet.risechain.com/dialog/",
      "has": [
        {
          "type": "host",
          "value": "(?<env>.*).wallet.risechain.com"
        }
      ],
      "source": "/dialog/"
    },
    {
      "destination": "https://:env.dialog.wallet.risechain.com/dialog/:match*",
      "has": [
        {
          "type": "host",
          "value": "(?<env>.*).wallet.risechain.com"
        }
      ],
      "source": "/dialog/:match*"
    },
    {
      "destination": "https://:env.manage.wallet.risechain.com/",
      "has": [
        {
          "type": "host",
          "value": "(?<env>.*).wallet.risechain.com"
        }
      ],
      "source": "/"
    },
    {
      "destination": "https://:env.manage.wallet.risechain.com/:match*",
      "has": [
        {
          "type": "host",
          "value": "(?<env>.*).wallet.risechain.com"
        }
      ],
      "source": "/:match*"
    },
    {
      "destination": "https://dialog.wallet.risechain.com/dialog/",
      "source": "/dialog/"
    },
    {
      "destination": "https://dialog.wallet.risechain.com/dialog/:match*",
      "source": "/dialog/:match*"
    },
    { "destination": "https://manage.wallet.risechain.com/", "source": "/" },
    {
      "destination": "https://manage.wallet.risechain.com/:match*",
      "source": "/:match*"
    }
  ]
}
